# Logs and temporary files
*.log
*.csv
*.tsv
.DS_Store
Thumbs.db

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*\~
.project
.pydevproject

# Zenodo / GitHub large files
*.zip
*.tar.gz
*.7z

# Environment variables
.env
.env.local
credentials.json
secrets.json

# MacOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Temporary folders
tmp/
temp/
cache/

# Lock files (if using specific tools)
Pipfile.lock
poetry.lock
